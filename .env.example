# Fall Hazard Detection System - Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI (for GPT-4 Vision) - optional
OPENAI_API_KEY=your_openai_key_here

# Google (for Gemini 2.0 Flash) - optional
GOOGLE_API_KEY=your_google_key_here

# Note: For local inference with Ollama (free), no API keys are needed.
# Just install Ollama and pull a model: ollama pull llava:7b
